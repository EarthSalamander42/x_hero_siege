<root>
	<styles>
		<include src="s2r://panorama/styles/dotastyles.vcss_c" />
		<include src="file://{resources}/styles/custom_game/custom_loading_screen.css"/>
	</styles>

	<scripts>
		<include src="file://{resources}/scripts/custom_game/custom_loading_screen.js"/>
	</scripts>

	<snippets>
		<snippet name="VoteChoice">
			<Panel class="vote-select-panel">
				<Label class="vote-select-title"/>

				<Label class="vote-select-description"/>

				<Button class="vote-button vote-gamemode-button">
					<Label class="vote-button-label" text="#loading_screen_vote_button" />
				</Button>
			</Panel>
		</snippet>
	</snippets>

	<Panel class="addon-root">
		<Panel class="background-dim-overlay" hittest="false" />

		<Panel class="vote-container-main">
			<Panel class="vote-content">
				<Label class="vote-content-title" text="#vote_settings"/>

				<!-- Filled dynamically in JS -->
				<Panel id="VoteContent" class="vote-select-panel-container"/>
			</Panel>
		</Panel>

		<Panel class="container-main">
			<Panel class="content-left-column">
				<Panel class="header">
					<Panel class="top-left-container">
					<Button id="HomeProfileContainer" onactivate="ToggleProfileModal(true);">
						<Panel id="ProfileSummaryCard" hittest="false">
							<DOTAAvatarImage id="ProfileSummaryAvatar" />

							<Panel id="ProfileSummaryTextWrap">
								<Panel id="ProfileSummaryNameRow">
									<Label id="ProfileSummaryName" text="#loading_screen_loading" />
									<Panel id="ProfileSummaryNameArrow" class="DemoArrow" />
								</Panel>
								<Label id="ProfileSummaryTitle" text="#loading_screen_unavailable" />
								<Panel class="profile-summary-row">
									<Label class="profile-summary-key" text="#loading_screen_player_level" />
									<Label id="ProfileSummaryLevel" class="profile-summary-value" text="-" />
								</Panel>
								<Panel class="profile-summary-row">
									<Label class="profile-summary-key" text="#loading_screen_winrate" />
									<Label id="ProfileSummaryWinrate" class="profile-summary-value" text="-" />
								</Panel>
							</Panel>
						</Panel>
					</Button>

					<Panel id="vote-container" class="vote-container">
						<Panel class="vote-header-container">
							<Label class="vote-title" text="#votes"/>
							<Panel class="vote-info"/>
						</Panel>

						<Panel id="vote-label-container" class="vote-label-container"/>

						<!-- <Label id="VoteGameModeCheck" class="vote-label vote-check" text="You have not voted yet." /> -->

						<Button id="MainVoteButton" class="vote-button" onactivate="ToggleVoteContainer(true);">
							<Label class="vote-button-label" text="#loading_screen_change_vote" />
						</Button>
					</Panel>
					</Panel>

					<Panel class="description-container">
					<Panel class="description-background">
						<Panel class="description-credit-wrap">
							<Label class="description-credit-text" text="#loading_screen_artwork_credit" />
							<Button class="description-credit-instagram-button" onactivate="ExternalBrowserGoToURL('https://www.instagram.com/duongcua_art');">
								<Label class="description-credit-instagram-label" text="#loading_screen_instagram_short" />
							</Button>
						</Panel>
					</Panel>

					<Panel class="description-text-container">
						<Label id="loading-title-text"/>

						<Label id="loading-subtitle-text" />

						<Label id="loading-description-text" />

						<Button class="vote-button" onactivate="ExternalBrowserGoToURL('https://mods.frostrose-studio.com')">
							<Label class="vote-button-label" text="#loading_screen_button" />
						</Button>
					</Panel>
					</Panel>
				</Panel>

				<Panel id="BottomFooterRoot" class="footer">
					<Panel class="bottom-button-container" hittest="false">
					<RadioButton id="BottomRadioPatreon" class="bottom-radio-button" onactivate="SwitchTab(3)" text="#loading_screen_tab_patreon" />
					<Label class="bottom-radio-separator" text="/" />
					<RadioButton id="BottomRadioCustomGames" class="bottom-radio-button" onactivate="SwitchTab(1)" text="#loading_screen_tab_custom_games" />
					<Label class="bottom-radio-separator" text="/" />
					<RadioButton id="BottomRadioTransifex" class="bottom-radio-button" onactivate="SwitchTab(2)" text="#loading_screen_tab_transifex" />
					<Panel id="BottomTabCountdownWrap" class="bottom-tab-countdown-wrap">
						<Panel class="bottom-tab-countdown-dot" />
						<Label id="BottomTabCountdown" class="bottom-tab-countdown" text="#loading_screen_tab_timer_default" />
					</Panel>
					<Panel class="bottom-button-spacer" />
					</Panel>

					<Panel class="bottom-footer-container">
					<Panel class="bottom-mods-container">
						<!-- Frostrose Battlefield -->
						<Button class="mod-cell">
							<Panel class="mod-image-container">
								<Image class="mod-image" src="file://panorama/images/custom_game/mods/modlist1.jpg"/>
								<Panel class="mod-background"/>
							</Panel>

							<Panel class="mod-footer">
								<Label class="mod-name" text="#loading_screen_patreon_modlist1"/>
							</Panel>
						</Button>

						<!-- Dota IMBA -->
						<Button class="mod-cell" onactivate="DOTADisplayURL('https://steamcommunity.com/sharedfiles/filedetails/?id=1350425247');">
							<Panel class="mod-image-container">
								<Image class="mod-image" src="file://panorama/images/custom_game/mods/modlist2.jpg"/>
								<Panel class="mod-background"/>
							</Panel>

							<Panel class="mod-footer">
								<Label class="mod-name" text="#loading_screen_patreon_modlist2"/>
							</Panel>
						</Button>

						<!-- X Hero Siege -->
						<Button class="mod-cell" onactivate="DOTADisplayURL('https://steamcommunity.com/sharedfiles/filedetails/?id=536682348');">
							<Panel class="mod-image-container">
								<Image class="mod-image" src="file://panorama/images/custom_game/mods/modlist3.jpg"/>
								<Panel class="mod-background"/>
							</Panel>

							<Panel class="mod-footer">
								<Label class="mod-name" text="#loading_screen_patreon_modlist3"/>
							</Panel>
						</Button>

						<!-- Pudge Wars -->
						<Button class="mod-cell" onactivate="DOTADisplayURL('https://steamcommunity.com/sharedfiles/filedetails/?id=296831818');">
							<Panel class="mod-image-container">
								<Image class="mod-image" src="file://panorama/images/custom_game/mods/modlist4.jpg"/>
								<Panel class="mod-background"/>
							</Panel>

							<Panel class="mod-footer">
								<Label class="mod-name" text="#loading_screen_patreon_modlist4"/>
							</Panel>
						</Button>

						<!-- Hero Line Wars -->
						<!--
						<Button class="mod-cell" onactivate="DOTADisplayURL('https://steamcommunity.com/sharedfiles/filedetails/?id=492195751');">
							<Panel class="mod-image-container">
								<Image class="mod-image" src="file://panorama/images/custom_game/mods/modlist1.jpg"/>
								<Panel class="mod-background"/>
							</Panel>

							<Panel class="mod-footer">
								<Label class="mod-name" text="#loading_screen_patreon_modlist5"/>
							</Panel>
						</Button>
-->

						<!-- Diretide -->
						<!-- <Button class="mod-cell" onactivate="DOTADisplayURL('https://steamcommunity.com/sharedfiles/filedetails/?id=544075277');">
							<Panel class="mod-image-container">
								<Image class="mod-image" src="file://panorama/images/custom_game/mods/modlist6.jpg"/>
								<Panel class="mod-background"/>
							</Panel>

							<Panel class="mod-footer">
								<Label class="mod-name" text="#loading_screen_patreon_modlist6"/>
							</Panel>
						</Button> -->
					</Panel>

					<Panel class="bottom-transifex-container">
						<Panel class="transifex-highlight-card">
							<Panel class="transifex-highlight-copy">
								<Label class="transifex-highlight-title" text="#loading_screen_transifex_section_title" />
								<Label class="transifex-highlight-subtitle" text="#loading_screen_transifex_section_subtitle" />
								<Label class="transifex-highlight-description" text="#loading_screen_transifex_section_description" />

								<Panel class="transifex-benefits-list">
									<Panel class="transifex-benefit-row">
										<Panel class="transifex-benefit-dot" />
										<Label class="transifex-benefit-text" text="#loading_screen_transifex_advantage_1" />
									</Panel>
									<Panel class="transifex-benefit-row">
										<Panel class="transifex-benefit-dot" />
										<Label class="transifex-benefit-text" text="#loading_screen_transifex_advantage_2" />
									</Panel>
								</Panel>

								<Panel class="transifex-highlight-footer">
									<Panel class="transifex-cta-row">
										<Button class="vote-button transifex-cta-button" onactivate="ExternalBrowserGoToURL('https://www.transifex.com/frostrose-studio/x-hero-siege/')">
											<Label class="vote-button-label" text="#loading_screen_transifex_cta_button" />
										</Button>
									</Panel>
								</Panel>
							</Panel>
						</Panel>
					</Panel>

					<Panel class="bottom-patreon-container">
						<Panel class="patreon-highlight-card">
							<Panel class="patreon-highlight-copy">
								<Label class="patreon-highlight-title" text="#loading_screen_patreon_section_title" />
								<Label class="patreon-highlight-subtitle" text="#loading_screen_patreon_section_subtitle" />

								<Panel class="patreon-benefits-list">
									<Panel class="patreon-benefit-row">
										<Panel class="patreon-benefit-dot" />
										<Label class="patreon-benefit-text" text="#loading_screen_patreon_advantage_1" />
									</Panel>
									<Panel class="patreon-benefit-row">
										<Panel class="patreon-benefit-dot" />
										<Label class="patreon-benefit-text" text="#loading_screen_patreon_advantage_2" />
									</Panel>
									<Panel class="patreon-benefit-row">
										<Panel class="patreon-benefit-dot" />
										<Label class="patreon-benefit-text" text="#loading_screen_patreon_advantage_3" />
									</Panel>
								</Panel>

								<Panel class="patreon-highlight-footer">
									<Label class="patreon-highlight-support-note" text="#loading_screen_patreon_support_note" />
								</Panel>
							</Panel>
							<Panel class="patreon-cta-side">
								<Button class="patreon-cta-image-button" onactivate="ExternalBrowserGoToURL('https://www.patreon.com/bePatron?u=2533325')" />
							</Panel>
						</Panel>
					</Panel>
					</Panel>
				</Panel>
			</Panel>

			<Panel id="PlayerLoadingSidebar" class="player-loading-sidebar">
				<Panel class="player-loading-header">
					<Label id="PlayerLoadingTitle" class="player-loading-title" text="#loading_screen_players" />
					<Label id="PlayerLoadingCounter" class="player-loading-counter" text="#loading_screen_loaded_counter_default" />
					<ProgressBar id="PlayerLoadingProgress" class="player-loading-progress" value="0.0" />
					<Panel class="player-loading-status-wrap">
						<Label id="PlayerLoadingWaiting" class="player-loading-status" text="#loading_screen_waiting_counter_default" />
					</Panel>
					<Label id="PlayerForceLaunchLabel" class="player-force-launch-label" text="#loading_screen_match_starts_in_default" />
					<Button id="PlayerReadyButton" class="player-ready-button" onactivate="OnCustomSetupReadyPressed();">
						<Label id="PlayerReadyButtonLabel" text="#loading_screen_mark_ready" />
					</Button>
				</Panel>

				<Panel id="PlayerLoadingList" class="player-loading-list" />
			</Panel>
		</Panel>

		<Panel id="ProfileModalOverlay">
			<Panel id="ProfileModalBackdrop" />

			<Panel id="ProfileModal">
				<Panel id="ProfileModalHeader">
					<Panel id="ProfileModalIdentity">
						<DOTAAvatarImage id="ProfileModalAvatar" />
						<Panel id="ProfileModalIdentityText">
							<Label id="ProfileModalName" text="#loading_screen_loading" />
							<Label id="ProfileModalSubtitle" text="#loading_screen_player_profile" />
						</Panel>
					</Panel>

					<Button id="ProfileModalClose" onactivate="ToggleProfileModal(false);">
						<Label text="X" />
					</Button>
				</Panel>

				<Panel id="ProfileModalBody">
					<Panel class="profile-modal-column">
						<Panel class="profile-modal-block">
							<Label class="profile-modal-block-title" text="#loading_screen_battle_pass" />
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_level" />
								<Label id="ProfileModalLevelValue" class="profile-modal-value" text="-" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_xp" />
								<Label id="ProfileModalXPValue" class="profile-modal-value" text="-" />
							</Panel>
							<ProgressBar id="ProfileModalXPProgress" class="profile-modal-progress" value="0.0" />
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_title" />
								<Label id="ProfileModalTitleValue" class="profile-modal-value" text="-" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_season_winrate" />
								<Label id="ProfileModalWinrateValue" class="profile-modal-value" text="-" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_donator" />
								<Label id="ProfileModalDonatorValue" class="profile-modal-value" text="-" />
							</Panel>
						</Panel>
					</Panel>

					<Panel class="profile-modal-column">
						<Panel class="profile-modal-block">
							<Label class="profile-modal-block-title" text="#loading_screen_rank" />

							<Panel id="ProfileModalRankBadge">
								<Panel id="ProfileModalRankTier" />
								<Panel id="ProfileModalRankPips" />
							</Panel>

							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_mmr_tier" />
								<Label id="ProfileModalMMRTitleValue" class="profile-modal-value" text="#loading_screen_na" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_leaderboard" />
								<Label id="ProfileModalLeaderboardValue" class="profile-modal-value" text="#loading_screen_na" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_connection" />
								<Label id="ProfileModalConnectionValue" class="profile-modal-value" text="#loading_screen_connection_loaded" />
							</Panel>
						</Panel>

						<Panel class="profile-modal-block">
							<Label class="profile-modal-block-title" text="#loading_screen_visibility" />
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_tag" />
								<Label id="ProfileModalTagVisibleValue" class="profile-modal-value" text="-" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_xp" />
								<Label id="ProfileModalXPVisibleValue" class="profile-modal-value" text="-" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_winrate" />
								<Label id="ProfileModalWinrateVisibleValue" class="profile-modal-value" text="-" />
							</Panel>
							<Panel class="profile-modal-row">
								<Label class="profile-modal-key" text="#loading_screen_bp_rewards" />
								<Label id="ProfileModalRewardsVisibleValue" class="profile-modal-value" text="-" />
							</Panel>
						</Panel>
					</Panel>
				</Panel>

				<Panel id="ProfileModalFooter">
					<Button id="ProfileModalSteamButton" class="vote-button" onactivate="OpenProfileSteamPage();">
						<Label class="vote-button-label" text="#loading_screen_open_steam_profile" />
					</Button>
					<Button id="ProfileModalWebsiteButton" class="vote-button" onactivate="ExternalBrowserGoToURL('https://mods.frostrose-studio.com')">
						<Label class="vote-button-label" text="#loading_screen_open_website" />
					</Button>
				</Panel>
			</Panel>
		</Panel>
	</Panel>
</root>
